# compiler
CC = gcc
# application name
TARGET = myapp
# source code list optional used in this makefile
SRCS = 
# linker script optional used in this makefile as well
LINK_OPTS_FILE = linkop.txt

# default target
all: $(TARGET)

# compile rules
$(TARGET):
	@gcc -v -o $(TARGET)64 main.c
	@echo "$(TARGET)64 here"
	@./$(TARGET)64

	@echo "$(TARGET)64_direct here"
	@/usr/lib/gcc/x86_64-linux-gnu/11/cc1 -quiet -v -imultiarch x86_64-linux-gnu main.c -quiet -dumpdir a- -dumpbase main.c -dumpbase-ext .c -mtune=generic -march=x86-64 -version -fasynchronous-unwind-tables -fstack-protector-strong -Wformat -Wformat-security -fstack-clash-protection -fcf-protection -o main64.s
	@as -v --64 -o main64.o main64.s
	@ld -o $(TARGET)64_direct --dynamic-linker /lib64/ld-linux-x86-64.so.2  /usr/lib/x86_64-linux-gnu/crt1.o /usr/lib/x86_64-linux-gnu/crti.o main64.o -L/usr/lib/x86_64-linux-gnu /usr/lib/x86_64-linux-gnu/libc.so /usr/lib/x86_64-linux-gnu/crtn.o
	@./$(TARGET)64_direct


# clean all targets which generated by this makefile
clean:
	rm -f $(TARGET)64 $(TARGET)32 $(TARGET)64*
	rm -f *.o *.s

# avoid if you have a file name also "all" or "clean"(avoid confilcts)
.PHONY: all clean
