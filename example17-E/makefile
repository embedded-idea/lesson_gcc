# compiler
CC = gcc
# application name
TARGET = myapp
# source code list optional used in this makefile
SRCS = 
# linker script optional used in this makefile as well
LINK_OPTS_FILE = linkop.txt

# default target
all: $(TARGET)

# compile rules
$(TARGET):
# -v when you compile prints all the steps
	@echo ""
	@gcc -v -o $(TARGET)64 main.c
	@echo "$(TARGET)64 here"
	@echo "please checkout logs"
	@./$(TARGET)64

# -### show steps but commands not executed
	@echo ""
	@gcc -### -o $(TARGET)64 main.c
	@echo "$(TARGET)64 here"
	@echo "please checkout logs"
	@./$(TARGET)64 

#Preprocess only; do not compile, assemble or link.
	@echo ""
	@gcc -E main.c -o main.i
	@echo "please checkout logs"



# clean all targets which generated by this makefile
clean:
	rm -f $(TARGET)64 $(TARGET)32 $(TARGET)64* *.map *.specs
	rm -f *.o *.s *.i

# avoid if you have a file name also "all" or "clean"(avoid confilcts)
.PHONY: all clean
