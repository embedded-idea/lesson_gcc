# compiler
CC = gcc
# application name
TARGET = myapp
# source code list optional used in this makefile
SRCS = 
# linker script optional used in this makefile as well
LINK_OPTS_FILE = linkop.txt

# default target
all: $(TARGET)

# compile rules
$(TARGET):
#-B globally adds a directory to the toolchain search path, which may include:
#compiler frontends (cc1, cc1plus)
#assembler (as)
#linker (ld)
#startup object files (.o)
#libraries (.so, .a)
	@echo ""
	@gcc -B /home/mzhang/home_work/gccbinutils/gcc-11.4.0_install/bin -v -o $(TARGET)64 main.c
	@echo "$(TARGET)64 here"
	@echo "please checkout logs"
	@./$(TARGET)64


# clean all targets which generated by this makefile
clean:
	rm -f $(TARGET)64 $(TARGET)32 $(TARGET)64* *.map *.specs
	rm -f *.o *.s *.i

# avoid if you have a file name also "all" or "clean"(avoid confilcts)
.PHONY: all clean
