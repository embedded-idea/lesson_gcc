# compiler
CC = gcc
# application name
TARGET = myapp
# source code list optional used in this makefile
SRCS = 
# linker script optional used in this makefile as well
LINK_OPTS_FILE = linkop.txt

# default target
all: $(TARGET)

# compile rules
$(TARGET):
#for sure you will hit error, because i have nothing on that path that i passed to sysroot
#but in the log you will see lot of folders are based on /home/mzhang/home_work/gccbinutils/lesson_gcc/example15--sysroot/include
	@echo ""
	@gcc --sysroot=/home/mzhang/home_work/gccbinutils/lesson_gcc/example15--sysroot/include -v -o $(TARGET)64 main.c
	@echo "$(TARGET)64 here"
	@echo "please checkout logs"
	@./$(TARGET)64


# clean all targets which generated by this makefile
clean:
	rm -f $(TARGET)64 $(TARGET)32 $(TARGET)64* *.map *.specs
	rm -f *.o *.s *.i

# avoid if you have a file name also "all" or "clean"(avoid confilcts)
.PHONY: all clean
