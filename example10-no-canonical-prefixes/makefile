# compiler
CC = gcc
# application name
TARGET = myapp
# source code list optional used in this makefile
SRCS = 
# linker script optional used in this makefile as well
LINK_OPTS_FILE = linkop.txt

# default target
all: $(TARGET)

# compile rules
$(TARGET):
	@gcc -v -o $(TARGET)64 main.c >log1
	@echo "$(TARGET)64 here with out -no-canonical-prefixes"
	@echo "please checkout the path in below logs"
	@./$(TARGET)64

	@echo ""
	@echo ""
	@gcc -no-canonical-prefixes -v -o $(TARGET)64_with main.c >log2
	@echo "$(TARGET)64 here with -no-canonical-prefixes"
	@echo "please checkout the path in below logs"
	@./$(TARGET)64_with

# clean all targets which generated by this makefile
clean:
	rm -f $(TARGET)64 $(TARGET)32 $(TARGET)64* *.map
	rm -f *.o *.s *.i

# avoid if you have a file name also "all" or "clean"(avoid confilcts)
.PHONY: all clean
