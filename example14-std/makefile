# compiler
CC = gcc
# application name
TARGET = myapp
# source code list optional used in this makefile
SRCS = 
# linker script optional used in this makefile as well
LINK_OPTS_FILE = linkop.txt

# default target
all: $(TARGET)

# compile rules
$(TARGET):

	@echo ""
	@gcc -std=c99 -o $(TARGET)64_c99 main.c
	@echo "$(TARGET)64_c99 here"
	@echo "please checkout logs"
	@./$(TARGET)64_c99

	@echo ""
	@gcc -std=c11 -o $(TARGET)64_c11 main.c
	@echo "$(TARGET)64_c11 here"
	@echo "please checkout logs"
	@./$(TARGET)64_c11

	@echo ""
	@gcc -std=gnu11 -o $(TARGET)64_gnu11 main.c
	@echo "$(TARGET)64_gnu11 here"
	@echo "please checkout logs"
	@./$(TARGET)64_gnu11

# clean all targets which generated by this makefile
clean:
	rm -f $(TARGET)64 $(TARGET)32 $(TARGET)64* *.map *.specs
	rm -f *.o *.s *.i

# avoid if you have a file name also "all" or "clean"(avoid confilcts)
.PHONY: all clean
